<% layout('/layouts/boilerplate') -%>

    <div class="admin-panel">
        <!-- Admin Header -->
        <div class="admin-header">
            <div class="admin-header-content">
                <div class="admin-title-group">
                    <div class="admin-icon">
                        <i class="fa-solid fa-calendar-check"></i>
                    </div>
                    <div>
                        <h1 class="admin-title">Booking Management</h1>
                        <p class="admin-subtitle">
                            <a href="/admin" style="color: inherit; text-decoration: none;">
                                <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filter Bar -->
        <div class="admin-toolbar">
            <form action="/admin/bookings" method="GET" class="admin-search-form">
                <div class="admin-search-wrapper">
                    <i class="fa-solid fa-magnifying-glass admin-search-icon"></i>
                    <input type="text" name="search" value="<%= searchQuery %>"
                        placeholder="Search by guest name, email, or listing..." class="admin-search-input">
                </div>
                <div class="admin-filter-group">
                    <select name="status" class="admin-filter-select">
                        <option value="">All Statuses</option>
                        <option value="confirmed" <%=statusFilter==='confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="completed" <%=statusFilter==='completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%=statusFilter==='cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                    <button type="submit" class="admin-search-btn">
                        <i class="fa-solid fa-filter"></i> Filter
                    </button>
                </div>
                <% if (searchQuery || statusFilter) { %>
                    <a href="/admin/bookings" class="admin-clear-btn">
                        <i class="fa-solid fa-xmark"></i> Clear
                    </a>
                    <% } %>
            </form>
            <div class="admin-results-count">
                <strong>
                    <%= bookings.length %>
                </strong> booking<%= bookings.length !==1 ? 's' : '' %> found
            </div>
        </div>

        <!-- Bookings Table -->
        <div class="admin-table-wrapper">
            <% if (bookings.length===0) { %>
                <div class="admin-empty">
                    <i class="fa-solid fa-calendar-xmark"></i>
                    <h3>No bookings found</h3>
                    <p>Try adjusting your search or filter criteria.</p>
                </div>
                <% } else { %>
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Booking ID</th>
                                <th>Guest</th>
                                <th>Property</th>
                                <th>Check-in</th>
                                <th>Check-out</th>
                                <th>Guests</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Payment</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for (const booking of bookings) { %>
                                <tr>
                                    <td class="booking-id-cell">
                                        <span class="booking-id-short" title="<%= booking._id %>">
                                            #<%= booking._id.toString().slice(-6).toUpperCase() %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="table-user-info">
                                            <strong>
                                                <%= booking.user ? booking.user.username : 'Deleted User' %>
                                            </strong>
                                            <small>
                                                <%= booking.user ? booking.user.email : 'N/A' %>
                                            </small>
                                        </div>
                                    </td>
                                    <td>
                                        <% if (booking.listing) { %>
                                            <a href="/listings/<%= booking.listing._id %>" class="table-listing-link">
                                                <%= booking.listing.title.length> 25 ?
                                                    booking.listing.title.substring(0, 25) + '...' :
                                                    booking.listing.title %>
                                            </a>
                                            <% } else { %>
                                                <span class="text-muted">Deleted Listing</span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <%= booking.checkIn.toLocaleDateString('en-IN', { day: 'numeric' ,
                                            month: 'short' , year: 'numeric' }) %>
                                    </td>
                                    <td>
                                        <%= booking.checkOut.toLocaleDateString('en-IN', { day: 'numeric' ,
                                            month: 'short' , year: 'numeric' }) %>
                                    </td>
                                    <td class="text-center">
                                        <%= booking.guests %>
                                    </td>
                                    <td class="amount-cell">₹ <%= booking.totalPrice.toLocaleString("en-IN") %>
                                    </td>
                                    <td>
                                        <span class="status-badge status-<%= booking.bookingStatus %>">
                                            <% if (booking.bookingStatus==='confirmed' ) { %>
                                                <i class="fa-solid fa-circle-check"></i>
                                                <% } else if (booking.bookingStatus==='completed' ) { %>
                                                    <i class="fa-solid fa-flag-checkered"></i>
                                                    <% } else { %>
                                                        <i class="fa-solid fa-circle-xmark"></i>
                                                        <% } %>
                                                            <%= booking.bookingStatus %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="payment-badge payment-<%= booking.paymentStatus %>">
                                            <%= booking.paymentStatus %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (booking.bookingStatus !=='cancelled' ) { %>
                                            <form action="/admin/bookings/<%= booking._id %>/cancel" method="POST"
                                                onsubmit="return confirm('Are you sure you want to cancel this booking?');"
                                                style="display: inline;">
                                                <button type="submit" class="admin-action-btn btn-danger-sm">
                                                    <i class="fa-solid fa-ban"></i> Cancel
                                                </button>
                                            </form>
                                            <% } else { %>
                                                <form action="/admin/bookings/<%= booking._id %>?_method=DELETE" method="POST"
                                                    onsubmit="return confirm('Are you sure you want to permanently delete this booking from the database? This action cannot be undone!');"
                                                    style="display: inline;">
                                                    <button type="submit" class="admin-action-btn btn-danger-sm">
                                                        <i class="fa-solid fa-trash"></i> Delete
                                                    </button>
                                                </form>
                                                <% } %>
                                    </td>
                                </tr>
                                <% } %>
                        </tbody>
                    </table>
                    <% } %>
        </div>
    </div>