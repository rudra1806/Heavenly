<% layout('/layouts/boilerplate') -%>

    <div class="payment-container">
        <!-- Progress Stepper -->
        <div class="booking-stepper">
            <div class="step completed">
                <div class="step-number"><i class="fa-solid fa-check" style="font-size: 0.7rem;"></i></div>
                <span class="step-label">Details</span>
            </div>
            <div class="step-line completed"></div>
            <div class="step active">
                <div class="step-number">2</div>
                <span class="step-label">Payment</span>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-number">3</div>
                <span class="step-label">Confirmed</span>
            </div>
        </div>

        <h2>Complete Your Payment</h2>

        <div class="payment-layout">
            <!-- Left Panel: Booking Details -->
            <div class="payment-details-panel">
                <h3><i class="fa-solid fa-receipt"></i> Booking Summary</h3>

                <div class="payment-property-card">
                    <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                    <div class="payment-property-info">
                        <h4>
                            <%= booking.listing.title %>
                        </h4>
                        <p><i class="fa-solid fa-location-dot"></i>
                            <%= booking.listing.location %>, <%= booking.listing.country %>
                        </p>
                    </div>
                </div>

                <div class="detail-row">
                    <span><i class="fa-solid fa-calendar-check"></i> Check-in</span>
                    <strong>
                        <%= booking.checkIn.toLocaleDateString('en-IN', { weekday: 'short' , month: 'short' ,
                            day: 'numeric' }) %>
                    </strong>
                </div>
                <div class="detail-row">
                    <span><i class="fa-solid fa-calendar-xmark"></i> Check-out</span>
                    <strong>
                        <%= booking.checkOut.toLocaleDateString('en-IN', { weekday: 'short' , month: 'short' ,
                            day: 'numeric' }) %>
                    </strong>
                </div>
                <div class="detail-row">
                    <span><i class="fa-solid fa-users"></i> Guests</span>
                    <strong>
                        <%= booking.guests %>
                            <%= booking.guests===1 ? 'Guest' : 'Guests' %>
                    </strong>
                </div>
                <div class="detail-row">
                    <span><i class="fa-solid fa-moon"></i> Duration</span>
                    <strong>
                        <%= Math.ceil((booking.checkOut - booking.checkIn) / (1000 * 60 * 60 * 24)) %> Nights
                    </strong>
                </div>
                <div class="detail-row total">
                    <span>Total Amount</span>
                    <strong>₹ <%= booking.totalPrice.toLocaleString("en-IN") %></strong>
                </div>
            </div>

            <!-- Right Panel: Payment Action -->
            <div class="payment-action-panel">
                <!-- Default state: Pay button -->
                <div id="paymentDefault">
                    <h3><i class="fa-solid fa-shield-halved"></i> Secure Payment</h3>

                    <div class="payment-notice info">
                        <i class="fa-solid fa-circle-info"></i>
                        <div>
                            <strong>Simulated Payment</strong> — This is a demo environment. No real transaction will
                            occur. Razorpay integration coming soon.
                        </div>
                    </div>

                    <div class="security-badges">
                        <div class="security-badge">
                            <i class="fa-solid fa-lock"></i>
                            256-bit SSL
                        </div>
                        <div class="security-badge">
                            <i class="fa-solid fa-shield-halved"></i>
                            Secure Checkout
                        </div>
                        <div class="security-badge">
                            <i class="fa-solid fa-credit-card"></i>
                            Razorpay Ready
                        </div>
                    </div>

                    <button type="button" id="payButton" class="btn-pay" onclick="processPayment()">
                        <span class="btn-shimmer"></span>
                        <i class="fa-solid fa-lock"></i>
                        Pay ₹ <%= booking.totalPrice.toLocaleString("en-IN") %>
                    </button>

                    <p class="payment-footer-text">
                        <i class="fa-solid fa-shield-check"></i>
                        Your payment information is encrypted and secure
                    </p>
                </div>

                <!-- Processing state -->
                <div id="paymentProcessing" class="payment-processing">
                    <div class="processing-spinner"></div>
                    <h4>Processing Payment...</h4>
                    <p>Please wait while we confirm your transaction</p>
                </div>

                <!-- Success state -->
                <div id="paymentSuccess" class="payment-success">
                    <div class="success-icon-wrapper">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <h4>Payment Successful!</h4>
                    <p>Your booking has been confirmed</p>
                    <div class="payment-id" id="paymentIdDisplay"></div>
                    <a href="#" id="viewBookingLink" class="btn-view-booking">
                        <i class="fa-solid fa-arrow-right"></i>
                        View Booking
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function processPayment() {
            const payButton = document.getElementById('payButton');
            const defaultState = document.getElementById('paymentDefault');
            const processingState = document.getElementById('paymentProcessing');
            const successState = document.getElementById('paymentSuccess');

            // Disable button
            payButton.disabled = true;

            // Show processing
            defaultState.style.display = 'none';
            processingState.classList.add('visible');

            try {
                // Send payment request
                const response = await fetch('/bookings/<%= booking._id %>/payment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                // Simulate a small delay for realistic feel
                await new Promise(resolve => setTimeout(resolve, 1500));

                if (data.success) {
                    // Show success
                    processingState.classList.remove('visible');
                    successState.classList.add('visible');

                    // Set payment ID
                    document.getElementById('paymentIdDisplay').textContent = 'Payment ID: ' + data.paymentId;
                    document.getElementById('viewBookingLink').href = '/bookings/' + data.bookingId;

                    // Show confetti
                    createConfetti();
                }
            } catch (error) {
                // Fallback: submit as a regular form
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/bookings/<%= booking._id %>/payment';
                document.body.appendChild(form);
                form.submit();
            }
        }

        function createConfetti() {
            const container = document.createElement('div');
            container.className = 'confetti-container';
            document.body.appendChild(container);

            const colors = ['#C2A86D', '#D4B87A', '#565449', '#2d8a5e', '#E5C98B', '#8B7D5B'];

            for (let i = 0; i < 75; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + '%';
                piece.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                piece.style.animationDelay = Math.random() * 2 + 's';
                piece.style.animationDuration = (2 + Math.random() * 2) + 's';
                piece.style.width = (6 + Math.random() * 8) + 'px';
                piece.style.height = (6 + Math.random() * 8) + 'px';
                container.appendChild(piece);
            }

            setTimeout(() => container.remove(), 5000);
        }
    </script>