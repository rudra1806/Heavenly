<% layout('/layouts/boilerplate') -%>

    <div class="listing-detail">
        <a href="/listings" class="back-button">
            <i class="fa-solid fa-arrow-left"></i>
            Back to Listings
        </a>

        <!-- Hero Image with Overlay -->
        <div class="listing-hero">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
            <div class="listing-hero-overlay">
                <h1>
                    <%= listing.title %>
                </h1>
                <div class="listing-hero-location">
                    <i class="fa-solid fa-location-dot"></i>
                    <%= listing.location %>, <%= listing.country %>
                </div>
            </div>
        </div>

        <!-- Two-Column Body -->
        <div class="listing-body">
            <!-- Main Content -->
            <div class="listing-main">
                <!-- Host Bar -->
                <div class="host-bar">
                    <div class="host-avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div class="host-info">
                        <span class="host-label">Hosted by</span>
                        <div class="host-name">@<%= listing.owner.username %>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                <div class="listing-description-card">
                    <h3 class="section-title"><i class="fa-solid fa-scroll"></i> About this property</h3>
                    <p>
                        <%= listing.description %>
                    </p>
                </div>

                <!-- Property Highlights -->
                <div>
                    <h3 class="section-title"><i class="fa-solid fa-sparkles"></i> Property Highlights</h3>
                    <div class="property-highlights">
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fa-solid fa-indian-rupee-sign"></i>
                            </div>
                            <div class="highlight-text">
                                <span class="highlight-label">Price</span>
                                <div class="highlight-value">₹ <%= listing.price.toLocaleString("en-IN") %> / night
                                </div>
                            </div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fa-solid fa-map-marker-alt"></i>
                            </div>
                            <div class="highlight-text">
                                <span class="highlight-label">Location</span>
                                <div class="highlight-value">
                                    <%= listing.location %>
                                </div>
                            </div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fa-solid fa-globe"></i>
                            </div>
                            <div class="highlight-text">
                                <span class="highlight-label">Country</span>
                                <div class="highlight-value">
                                    <%= listing.country %>
                                </div>
                            </div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fa-solid fa-users"></i>
                            </div>
                            <div class="highlight-text">
                                <span class="highlight-label">Max Guests</span>
                                <div class="highlight-value">
                                    <%= listing.maxGuests || 10 %> Guests
                                </div>
                            </div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fa-solid fa-star"></i>
                            </div>
                            <div class="highlight-text">
                                <span class="highlight-label">Reviews</span>
                                <div class="highlight-value">
                                    <%= listing.reviews.length %>
                                        <%= listing.reviews.length===1 ? 'Review' : 'Reviews' %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Map Section -->
                <div class="listing-map-card">
                    <div class="map-header">
                        <h3 class="section-title"><i class="fa-solid fa-map-location-dot"></i> Where you'll be</h3>
                    </div>
                    <% var coordsExist=listing.geometry && Array.isArray(listing.geometry.coordinates) &&
                        listing.geometry.coordinates.length> 1;
                        var lng = coordsExist ? listing.geometry.coordinates[0] : 0;
                        var lat = coordsExist ? listing.geometry.coordinates[1] : 0;
                        %>
                        <div id="map" data-lng="<%= lng %>" data-lat="<%= lat %>" data-title="<%= listing.title %>"
                            data-location="<%= listing.location %>, <%= listing.country %>"
                            data-price="<%= listing.price %>">
                        </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="listing-sidebar">
                <!-- Booking Widget -->
                <% if (currentUser && !listing.owner._id.equals(currentUser._id)) { %>
                    <div class="booking-widget">
                        <div class="booking-price">
                            <span class="price-amount">₹ <%= listing.price.toLocaleString("en-IN") %></span>
                            <span class="price-unit">/ night</span>
                        </div>
                        <a href="/listings/<%= listing._id %>/book" class="btn-book-now">
                            <i class="fa-solid fa-calendar-check"></i>
                            Book This Property
                        </a>
                        <div class="booking-features">
                            <div class="booking-feature">
                                <i class="fa-solid fa-check"></i>
                                <span>Free cancellation available</span>
                            </div>
                            <div class="booking-feature">
                                <i class="fa-solid fa-check"></i>
                                <span>Instant confirmation</span>
                            </div>
                            <div class="booking-feature">
                                <i class="fa-solid fa-check"></i>
                                <span>Secure payment</span>
                            </div>
                        </div>
                    </div>
                    <% } else if (!currentUser) { %>
                        <div class="booking-widget">
                            <div class="booking-price">
                                <span class="price-amount">₹ <%= listing.price.toLocaleString("en-IN") %></span>
                                <span class="price-unit">/ night</span>
                            </div>
                            <a href="/login" class="btn-book-now">
                                <i class="fa-solid fa-right-to-bracket"></i>
                                Login to Book
                            </a>
                            <div class="booking-features">
                                <div class="booking-feature">
                                    <i class="fa-solid fa-check"></i>
                                    <span>Free cancellation available</span>
                                </div>
                                <div class="booking-feature">
                                    <i class="fa-solid fa-check"></i>
                                    <span>Instant confirmation</span>
                                </div>
                                <div class="booking-feature">
                                    <i class="fa-solid fa-check"></i>
                                    <span>Secure payment</span>
                                </div>
                            </div>
                        </div>
                        <% } %>

                            <!-- Owner Actions -->
                            <% if (currentUser && (listing.owner._id.equals(currentUser._id) ||
                                currentUser.role==='admin' )) { %>
                                <div class="owner-actions-card">
                                    <h4><i class="fa-solid fa-gear"></i> Manage Listing</h4>
                                    <div class="listing-actions">
                                        <form action="/listings/<%= listing._id %>/edit" method="get">
                                            <button type="submit">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                                Edit Listing
                                            </button>
                                        </form>
                                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="post"
                                            onsubmit="return confirm('Are you sure you want to delete this listing? This action cannot be undone.');">
                                            <button type="submit">
                                                <i class="fa-solid fa-trash"></i>
                                                Delete Listing
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <% } %>
            </div>
        </div>

        <!-- Reviews Section — Full Width -->
        <div class="review-section">
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="post" class="review-form needs-validation"
                novalidate>
                <div class="rating-group">
                    <label for="rating">Rating</label>
                    <fieldset class="star-rating">
                        <input type="radio" id="star5" name="review[rating]" value="5" required>
                        <label for="star5" title="5 stars"><i class="fa-solid fa-star"></i></label>

                        <input type="radio" id="star4" name="review[rating]" value="4">
                        <label for="star4" title="4 stars"><i class="fa-solid fa-star"></i></label>

                        <input type="radio" id="star3" name="review[rating]" value="3">
                        <label for="star3" title="3 stars"><i class="fa-solid fa-star"></i></label>

                        <input type="radio" id="star2" name="review[rating]" value="2">
                        <label for="star2" title="2 stars"><i class="fa-solid fa-star"></i></label>

                        <input type="radio" id="star1" name="review[rating]" value="1">
                        <label for="star1" title="1 star"><i class="fa-solid fa-star"></i></label>
                    </fieldset>
                    <div class="invalid-feedback">Please select a rating.</div>
                </div>
                <div class="comment-group">
                    <label for="comment">Your Review</label>
                    <textarea id="comment" name="review[comment]" rows="4"
                        placeholder="Share your experience about this property..." class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">Please write a review.</div>
                </div>
                <button type="submit" class="submit-review-btn">
                    <i class="fa-solid fa-paper-plane"></i>
                    Submit Review
                </button>
            </form>

            <div class="reviews-container">
                <h4>Reviews</h4>
                <% if (listing.reviews.length===0) { %>
                    <p class="no-reviews">No reviews yet. Be the first to review this property!</p>
                    <% } else { %>
                        <ul class="review-list">
                            <% for (let review of listing.reviews) { %>
                                <li class="review-item">
                                    <div class="review-header">
                                        <div class="review-user">
                                            <i class="fa-solid fa-user-circle"></i>
                                            <span class="review-author">
                                                <%= review.author.username %>
                                            </span>
                                        </div>
                                        <% if (currentUser && (review.author._id.equals(currentUser._id) ||
                                            currentUser.role==='admin' )) { %>
                                            <form
                                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                method="post" class="delete-review-form">
                                                <button type="submit" class="delete-review-btn" title="Delete Review">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                            <% } %>
                                    </div>
                                    <div class="review-rating">
                                        <% for (let i=0; i < review.rating; i++) { %>
                                            <i class="fa-solid fa-star"></i>
                                            <% } %>
                                                <% for (let i=review.rating; i < 5; i++) { %>
                                                    <i class="fa-regular fa-star"></i>
                                                    <% } %>
                                    </div>
                                    <p>
                                        <%= review.comment %>
                                    </p>
                                </li>
                                <% } %>
                        </ul>
                        <% } %>
            </div>
        </div>
    </div>

    <!-- MapLibre script -->
    <script defer src="/js/showMap.js"></script>