<% layout('/layouts/boilerplate') -%>

    <div class="booking-form-container">
        <a href="/listings/<%= listing._id %>" class="back-link">
            <i class="fa-solid fa-arrow-left"></i>
            Back to Listing
        </a>

        <!-- Progress Stepper -->
        <div class="booking-stepper">
            <div class="step active">
                <div class="step-number">1</div>
                <span class="step-label">Details</span>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-number">2</div>
                <span class="step-label">Payment</span>
            </div>
            <div class="step-line"></div>
            <div class="step">
                <div class="step-number">3</div>
                <span class="step-label">Confirmed</span>
            </div>
        </div>

        <h2>Book Your Stay</h2>

        <div class="booking-summary">
            <div class="listing-preview">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                <div class="listing-info">
                    <h3>
                        <%= listing.title %>
                    </h3>
                    <p><i class="fa-solid fa-location-dot"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                    <p class="price">₹ <%= listing.price.toLocaleString("en-IN") %> / night</p>
                </div>
            </div>
        </div>

        <form action="/listings/<%= listing._id %>/book" method="POST" class="booking-form needs-validation" novalidate>
            <div class="form-row-dates">
                <div class="form-group">
                    <label for="checkIn">
                        <i class="fa-solid fa-calendar-check"></i>
                        Check-in Date
                    </label>
                    <input type="date" id="checkIn" name="checkIn" class="form-control" required
                        min="<%= new Date().toISOString().split('T')[0] %>">
                    <div class="invalid-feedback">Please select a check-in date.</div>
                </div>

                <div class="form-group">
                    <label for="checkOut">
                        <i class="fa-solid fa-calendar-xmark"></i>
                        Check-out Date
                    </label>
                    <input type="date" id="checkOut" name="checkOut" class="form-control" required
                        min="<%= new Date().toISOString().split('T')[0] %>">
                    <div class="invalid-feedback">Please select a check-out date.</div>
                </div>
            </div>

            <div class="form-group">
                <label for="guests">
                    <i class="fa-solid fa-users"></i>
                    Number of Guests
                </label>
                <input type="number" id="guests" name="guests" class="form-control" min="1"
                    max="<%= listing.maxGuests || 10 %>" value="1" required>
                <small style="color: var(--bk-text-muted); font-size: 0.8rem; margin-top: 0.35rem; display: block;">
                    <i class="fa-solid fa-circle-info" style="color: var(--bk-gold); margin-right: 0.25rem;"></i>
                    Maximum <strong>
                        <%= listing.maxGuests || 10 %>
                    </strong> guests allowed
                </small>
                <div class="invalid-feedback">Please enter between 1 and <%= listing.maxGuests || 10 %> guests.</div>
            </div>

            <div class="price-breakdown" id="priceBreakdown" style="display: none;">
                <h4><i class="fa-solid fa-receipt"></i> Price Breakdown</h4>
                <div class="price-item">
                    <span>₹ <span id="pricePerNight">
                            <%= listing.price.toLocaleString("en-IN") %>
                        </span> × <span id="nights">0</span> nights</span>
                    <span>₹ <span id="subtotal">0</span></span>
                </div>
                <div class="price-item">
                    <span>Service fee (10%)</span>
                    <span>₹ <span id="serviceFee">0</span></span>
                </div>
                <div class="price-total">
                    <strong>Total</strong>
                    <strong>₹ <span id="totalPrice">0</span></strong>
                </div>
            </div>

            <button type="submit" class="btn-book">
                <i class="fa-solid fa-arrow-right"></i>
                Proceed to Payment
            </button>
        </form>
    </div>

    <script>
        const checkInInput = document.getElementById('checkIn');
        const checkOutInput = document.getElementById('checkOut');
        const pricePerNight = <%= listing.price %>;
        const priceBreakdown = document.getElementById('priceBreakdown');

        function calculatePrice() {
            const checkIn = new Date(checkInInput.value);
            const checkOut = new Date(checkOutInput.value);

            if (checkIn && checkOut && checkOut > checkIn) {
                const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
                const subtotal = nights * pricePerNight;
                const serviceFee = Math.round(subtotal * 0.10);
                const total = subtotal + serviceFee;

                document.getElementById('nights').textContent = nights;
                document.getElementById('subtotal').textContent = subtotal.toLocaleString("en-IN");
                document.getElementById('serviceFee').textContent = serviceFee.toLocaleString("en-IN");
                document.getElementById('totalPrice').textContent = total.toLocaleString("en-IN");
                priceBreakdown.style.display = 'block';
            } else {
                priceBreakdown.style.display = 'none';
            }
        }

        checkInInput.addEventListener('change', () => {
            checkOutInput.min = checkInInput.value;
            calculatePrice();
        });

        checkOutInput.addEventListener('change', calculatePrice);
    </script>