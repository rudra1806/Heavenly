<% layout('/layouts/boilerplate') -%>

    <div class="bookings-container">
        <h2>My Bookings</h2>

        <% if (bookings.length===0) { %>
            <div class="no-bookings">
                <div class="empty-icon">
                    <i class="fa-solid fa-suitcase-rolling"></i>
                </div>
                <h3>No bookings yet</h3>
                <p>Start exploring amazing properties and book your next stay!</p>
                <a href="/listings" class="btn-explore">
                    <i class="fa-solid fa-compass"></i>
                    Explore Listings
                </a>
            </div>
            <% } else { %>
                <div class="bookings-grid">
                    <% bookings.forEach(booking=> { %>
                        <div class="booking-card">
                            <div class="booking-image">
                                <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                                <div class="booking-badges">
                                    <span class="badge badge-<%= booking.bookingStatus %>">
                                        <%= booking.bookingStatus %>
                                    </span>
                                </div>
                                <% if (booking.bookingStatus==='cancelled' ) { %>
                                    <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST"
                                        onsubmit="return confirm('Remove this booking from your history?');">
                                        <button type="submit" class="btn-remove-card" title="Remove from view">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </form>
                                    <% } %>
                            </div>
                            <div class="booking-card-content">
                                <h3>
                                    <%= booking.listing.title %>
                                </h3>
                                <p class="location">
                                    <i class="fa-solid fa-location-dot"></i>
                                    <%= booking.listing.location %>, <%= booking.listing.country %>
                                </p>
                                <div class="booking-dates">
                                    <div class="date-item">
                                        <i class="fa-solid fa-calendar-check"></i>
                                        <span>
                                            <%= booking.checkIn.toLocaleDateString('en-IN', { month: 'short' ,
                                                day: 'numeric' }) %>
                                        </span>
                                    </div>
                                    <i class="fa-solid fa-arrow-right"></i>
                                    <div class="date-item">
                                        <i class="fa-solid fa-calendar-xmark"></i>
                                        <span>
                                            <%= booking.checkOut.toLocaleDateString('en-IN', { month: 'short' ,
                                                day: 'numeric' }) %>
                                        </span>
                                    </div>
                                </div>
                                <div class="booking-meta">
                                    <span><i class="fa-solid fa-users"></i>
                                        <%= booking.guests %> Guests
                                    </span>
                                    <span class="price">₹ <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                </div>
                                <div class="booking-card-actions">
                                    <a href="/bookings/<%= booking._id %>" class="btn-view">
                                        <i class="fa-solid fa-eye"></i> View Details
                                    </a>
                                    <% if (booking.bookingStatus==='confirmed' && booking.paymentStatus==='completed' )
                                        { %>
                                        <form action="/bookings/<%= booking._id %>/cancel" method="POST"
                                            style="display: inline;" onsubmit="return confirm('Cancel this booking?');">
                                            <button type="submit" class="btn-cancel-small">Cancel</button>
                                        </form>
                                        <% } %>
                                            <% if (booking.paymentStatus==='pending' ) { %>
                                                <a href="/bookings/<%= booking._id %>/payment" class="btn-view"
                                                    style="background: linear-gradient(135deg, var(--bk-success), var(--bk-success-dark));">
                                                    Pay Now
                                                </a>
                                                <% } %>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </div>