<% layout('/layouts/boilerplate') -%>

    <div class="booking-detail-container">
        <a href="/bookings" class="back-link">
            <i class="fa-solid fa-arrow-left"></i>
            Back to My Bookings
        </a>

        <!-- Progress Stepper - Completed -->
        <div class="booking-stepper">
            <div class="step completed">
                <div class="step-number"><i class="fa-solid fa-check" style="font-size: 0.7rem;"></i></div>
                <span class="step-label">Details</span>
            </div>
            <div class="step-line completed"></div>
            <div class="step completed">
                <div class="step-number"><i class="fa-solid fa-check" style="font-size: 0.7rem;"></i></div>
                <span class="step-label">Payment</span>
            </div>
            <div class="step-line completed"></div>
            <div
                class="step <% if (booking.bookingStatus === 'confirmed' && booking.paymentStatus === 'completed') { %>completed<% } else { %>active<% } %>">
                <div class="step-number">
                    <% if (booking.bookingStatus==='confirmed' && booking.paymentStatus==='completed' ) { %>
                        <i class="fa-solid fa-check" style="font-size: 0.7rem;"></i>
                        <% } else { %>
                            3
                            <% } %>
                </div>
                <span class="step-label">Confirmed</span>
            </div>
        </div>

        <div class="booking-header">
            <h2>Booking Confirmation</h2>
            <div class="status-badges">
                <span class="badge badge-<%= booking.bookingStatus %>">
                    <i
                        class="fa-solid fa-<%= booking.bookingStatus === 'confirmed' ? 'circle-check' : booking.bookingStatus === 'cancelled' ? 'circle-xmark' : 'circle-check' %>"></i>
                    <%= booking.bookingStatus.toUpperCase() %>
                </span>
                <span class="badge badge-<%= booking.paymentStatus %>">
                    <i
                        class="fa-solid fa-<%= booking.paymentStatus === 'completed' ? 'check' : booking.paymentStatus === 'pending' ? 'clock' : 'xmark' %>"></i>
                    <%= booking.paymentStatus==='completed' ? 'PAID' : booking.paymentStatus.toUpperCase() %>
                </span>
            </div>
        </div>

        <div class="booking-content">
            <% if (booking.bookingStatus==='confirmed' && booking.paymentStatus==='completed' ) { %>
                <div class="booking-success-banner">
                    <div class="banner-icon">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <div class="banner-text">
                        <h4>Booking Confirmed!</h4>
                        <p>Your reservation is all set. We look forward to hosting you!</p>
                    </div>
                </div>
                <% } %>

                    <div class="booking-content-inner">
                        <!-- Property Showcase -->
                        <div class="listing-section">
                            <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                            <div class="listing-details">
                                <h3>
                                    <%= booking.listing.title %>
                                </h3>
                                <p><i class="fa-solid fa-location-dot"></i>
                                    <%= booking.listing.location %>, <%= booking.listing.country %>
                                </p>
                                <a href="/listings/<%= booking.listing._id %>" class="view-listing-btn">
                                    <i class="fa-solid fa-external-link"></i>
                                    View Property
                                </a>
                            </div>
                        </div>

                        <!-- Booking Information Grid -->
                        <div class="booking-info-section">
                            <h3><i class="fa-solid fa-calendar-days"></i> Booking Information</h3>
                            <div class="info-grid">
                                <div class="info-item">
                                    <i class="fa-solid fa-calendar-check"></i>
                                    <div>
                                        <span class="label">Check-in</span>
                                        <strong>
                                            <%= booking.checkIn.toLocaleDateString('en-IN', { weekday: 'short' ,
                                                year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                        </strong>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fa-solid fa-calendar-xmark"></i>
                                    <div>
                                        <span class="label">Check-out</span>
                                        <strong>
                                            <%= booking.checkOut.toLocaleDateString('en-IN', { weekday: 'short' ,
                                                year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                        </strong>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fa-solid fa-users"></i>
                                    <div>
                                        <span class="label">Guests</span>
                                        <strong>
                                            <%= booking.guests %>
                                                <%= booking.guests===1 ? 'Guest' : 'Guests' %>
                                        </strong>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fa-solid fa-moon"></i>
                                    <div>
                                        <span class="label">Duration</span>
                                        <strong>
                                            <%= Math.ceil((booking.checkOut - booking.checkIn) / (1000 * 60 * 60 * 24))
                                                %> Nights
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Details -->
                        <div class="payment-section">
                            <h3><i class="fa-solid fa-credit-card"></i> Payment Details</h3>
                            <div class="payment-info">
                                <div class="payment-row">
                                    <span>Total Amount</span>
                                    <strong>₹ <%= booking.totalPrice.toLocaleString("en-IN") %></strong>
                                </div>
                                <div class="payment-row">
                                    <span>Payment Status</span>
                                    <strong
                                        style="color: <%= booking.paymentStatus === 'completed' ? 'var(--bk-success)' : booking.paymentStatus === 'pending' ? 'var(--bk-warning)' : 'var(--bk-danger)' %>;">
                                        <i
                                            class="fa-solid fa-<%= booking.paymentStatus === 'completed' ? 'circle-check' : booking.paymentStatus === 'pending' ? 'clock' : 'circle-xmark' %>"></i>
                                        <%= booking.paymentStatus==='completed' ? 'Paid' :
                                            booking.paymentStatus.charAt(0).toUpperCase() +
                                            booking.paymentStatus.slice(1) %>
                                    </strong>
                                </div>
                                <% if (booking.paymentId) { %>
                                    <div class="payment-row">
                                        <span>Payment ID</span>
                                        <code><%= booking.paymentId %></code>
                                    </div>
                                    <% } %>
                                        <div class="payment-row">
                                            <span>Booking Date</span>
                                            <span>
                                                <%= booking.createdAt.toLocaleDateString('en-IN', { year: 'numeric' ,
                                                    month: 'long' , day: 'numeric' }) %>
                                            </span>
                                        </div>
                            </div>
                        </div>

                        <!-- Cancel Action -->
                        <% if (booking.bookingStatus==='confirmed' && booking.paymentStatus==='completed' ) { %>
                            <div class="booking-actions">
                                <form action="/bookings/<%= booking._id %>/cancel" method="POST"
                                    onsubmit="return confirm('Are you sure you want to cancel this booking? This action cannot be undone.');">
                                    <button type="submit" class="btn-cancel">
                                        <i class="fa-solid fa-times-circle"></i>
                                        Cancel Booking
                                    </button>
                                </form>
                            </div>
                            <% } %>

                                <!-- Complete Payment Action -->
                                <% if (booking.paymentStatus==='pending' ) { %>
                                    <div class="booking-actions">
                                        <a href="/bookings/<%= booking._id %>/payment" class="btn-view-booking">
                                            <i class="fa-solid fa-credit-card"></i>
                                            Complete Payment
                                        </a>
                                    </div>
                                    <% } %>
                    </div>
        </div>
    </div>