<% layout('/layouts/boilerplate') -%>

<div class="dash-panel">
    <!-- Dashboard Header -->
    <div class="dash-header">
        <div class="dash-header-content">
            <div class="dash-title-group">
                <a href="/dashboard" class="dash-back-link">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div>
                    <h1 class="dash-title">My Bookings</h1>
                    <p class="dash-subtitle">Your travel reservations</p>
                </div>
            </div>
            <div class="dash-quick-actions">
                <a href="/listings" class="dash-quick-btn dash-quick-btn-primary">
                    <i class="fa-solid fa-compass"></i> Explore Listings
                </a>
            </div>
        </div>
    </div>

    <!-- Sidebar + Content Layout -->
    <div class="dash-layout">
        <!-- Sidebar Navigation -->
        <% locals.activeDash = 'bookings'; %>
        <%- include('../includes/dashboard-sidebar') %>

        <!-- Main Content -->
        <div class="dash-content">
            <% if (bookings.length === 0) { %>
                <div class="dash-empty-state-lg">
                    <div class="dash-empty-icon">
                        <i class="fa-solid fa-suitcase-rolling"></i>
                    </div>
                    <h3>No bookings yet</h3>
                    <p>Start exploring amazing properties and book your next stay!</p>
                    <a href="/listings" class="dash-btn-primary">
                        <i class="fa-solid fa-compass"></i> Explore Listings
                    </a>
                </div>
            <% } else { %>
                <div class="dash-bookings-grid">
                    <% bookings.forEach(booking => { %>
                        <div class="dash-booking-card">
                            <div class="dash-booking-img">
                                <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                                <div class="dash-booking-badges">
                                    <span class="dash-badge dash-badge-<%= booking.bookingStatus %>">
                                        <%= booking.bookingStatus %>
                                    </span>
                                    <span class="dash-badge dash-badge-<%= booking.paymentStatus %>">
                                        <%= booking.paymentStatus === 'completed' ? 'paid' : booking.paymentStatus %>
                                    </span>
                                </div>
                            </div>
                            <div class="dash-booking-body">
                                <h4><%= booking.listing.title %></h4>
                                <p class="dash-booking-location">
                                    <i class="fa-solid fa-location-dot"></i>
                                    <%= booking.listing.location %>, <%= booking.listing.country %>
                                </p>
                                <div class="dash-booking-dates">
                                    <div class="dash-date-item">
                                        <i class="fa-solid fa-calendar-check"></i>
                                        <span><%= booking.checkIn.toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                    </div>
                                    <i class="fa-solid fa-arrow-right" style="color: var(--text-muted); font-size: 0.75rem;"></i>
                                    <div class="dash-date-item">
                                        <i class="fa-solid fa-calendar-xmark"></i>
                                        <span><%= booking.checkOut.toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                    </div>
                                </div>
                                <div class="dash-booking-meta">
                                    <span><i class="fa-solid fa-users"></i> <%= booking.guests %> Guests</span>
                                    <span class="dash-booking-price">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                </div>
                                <div class="dash-booking-actions">
                                    <a href="/bookings/<%= booking._id %>" class="dash-btn-sm dash-btn-outline">
                                        <i class="fa-solid fa-eye"></i> View Details
                                    </a>
                                    <% if (booking.bookingStatus === 'confirmed' && booking.paymentStatus === 'completed') { %>
                                        <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                            <button type="submit" class="dash-btn-sm dash-btn-danger">
                                                <i class="fa-solid fa-xmark"></i> Cancel
                                            </button>
                                        </form>
                                    <% } %>
                                    <% if (booking.paymentStatus === 'pending') { %>
                                        <a href="/bookings/<%= booking._id %>/payment" class="dash-btn-sm dash-btn-success">
                                            <i class="fa-solid fa-credit-card"></i> Pay Now
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>
</div>
