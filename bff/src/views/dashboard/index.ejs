<% layout('/layouts/boilerplate') -%>

<div class="dash-panel">
    <!-- Dashboard Header -->
    <div class="dash-header">
        <div class="dash-header-content">
            <div class="dash-title-group">
                <div class="dash-icon">
                    <i class="fa-solid fa-gauge-high"></i>
                </div>
                <div>
                    <h1 class="dash-title">Dashboard</h1>
                    <p class="dash-subtitle">Welcome back, <strong><%= currentUser.username %></strong></p>
                </div>
            </div>
            <div class="dash-quick-actions">
                <a href="/dashboard/bookings" class="dash-quick-btn">
                    <i class="fa-solid fa-suitcase"></i> My Bookings
                </a>
                <a href="/dashboard/listings" class="dash-quick-btn">
                    <i class="fa-solid fa-building"></i> My Listings
                </a>
                <a href="/listings/new" class="dash-quick-btn dash-quick-btn-primary">
                    <i class="fa-solid fa-plus"></i> New Listing
                </a>
            </div>
        </div>
    </div>

    <!-- Sidebar + Content Layout -->
    <div class="dash-layout">
        <!-- Sidebar Navigation -->
        <% locals.activeDash = 'overview'; %>
        <%- include('../includes/dashboard-sidebar') %>

        <!-- Main Content -->
        <div class="dash-content">
            <!-- ========== ME AS GUEST SECTION ========== -->
            <div class="dash-role-section">
                <div class="dash-role-header">
                    <div class="dash-role-title">
                        <i class="fa-solid fa-suitcase-rolling"></i>
                        <h2>Me as Guest</h2>
                    </div>
                    <p class="dash-role-subtitle">Your travel bookings and experiences</p>
                </div>

                <!-- Guest Stats -->
                <div class="dash-stats">
                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(86, 84, 73, 0.1); color: var(--secondary);">
                            <i class="fa-solid fa-suitcase"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= totalGuestBookings %></h3>
                            <p class="dash-stat-label">Total Bookings</p>
                            <% if (activeGuestBookings > 0) { %>
                                <small style="color: #2d8a5e;"><%= activeGuestBookings %> upcoming</small>
                            <% } %>
                        </div>
                        <a href="/dashboard/bookings" class="dash-stat-link">
                            View <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(194, 168, 109, 0.15); color: #C2A86D;">
                            <i class="fa-solid fa-wallet"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number">₹<%= totalSpent.toLocaleString("en-IN") %></h3>
                            <p class="dash-stat-label">Total Spent</p>
                            <% if (completedGuestBookings > 0) { %>
                                <small style="color: var(--text-muted);"><%= completedGuestBookings %> completed trips</small>
                            <% } %>
                        </div>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(45, 138, 94, 0.1); color: #2d8a5e;">
                            <i class="fa-solid fa-map-location-dot"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= uniquePlaces %></h3>
                            <p class="dash-stat-label">Places Visited</p>
                        </div>
                    </div>
                </div>

                <!-- Recent Guest Bookings -->
                <div class="dash-recent-card">
                    <div class="dash-recent-header">
                        <h3><i class="fa-solid fa-clock-rotate-left"></i> Recent Bookings</h3>
                        <a href="/dashboard/bookings" class="dash-view-all">View All</a>
                    </div>
                    <div class="dash-recent-list">
                        <% if (recentGuestBookings.length === 0) { %>
                            <div class="dash-empty-state">
                                <i class="fa-solid fa-suitcase-rolling"></i>
                                <p>No bookings yet. <a href="/listings">Explore listings</a></p>
                            </div>
                        <% } else { %>
                            <% recentGuestBookings.forEach(booking => { %>
                                <div class="dash-recent-item">
                                    <div class="dash-recent-img">
                                        <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                                    </div>
                                    <div class="dash-recent-info">
                                        <h4><%= booking.listing.title %></h4>
                                        <p>
                                            <%= booking.checkIn.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' }) %>
                                            —
                                            <%= booking.checkOut.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' }) %>
                                        </p>
                                    </div>
                                    <div class="dash-recent-meta">
                                        <span class="dash-badge dash-badge-<%= booking.bookingStatus %>"><%= booking.bookingStatus %></span>
                                        <span class="dash-price">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- ========== ME AS HOST SECTION ========== -->
            <div class="dash-role-section">
                <div class="dash-role-header">
                    <div class="dash-role-title">
                        <i class="fa-solid fa-house-user"></i>
                        <h2>Me as Host</h2>
                    </div>
                    <p class="dash-role-subtitle">Your properties and hosting performance</p>
                </div>

                <!-- Host Stats -->
                <div class="dash-stats">
                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(86, 84, 73, 0.1); color: var(--secondary);">
                            <i class="fa-solid fa-building"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= totalListings %></h3>
                            <p class="dash-stat-label">Total Listings</p>
                        </div>
                        <a href="/dashboard/listings" class="dash-stat-link">
                            View <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(45, 138, 94, 0.1); color: #2d8a5e;">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= activeListings %></h3>
                            <p class="dash-stat-label">Active Listings</p>
                            <% if (inactiveListings > 0) { %>
                                <small style="color: var(--text-muted);"><%= inactiveListings %> inactive</small>
                            <% } %>
                        </div>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(194, 168, 109, 0.15); color: #C2A86D;">
                            <i class="fa-solid fa-indian-rupee-sign"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number">₹<%= totalRevenue.toLocaleString("en-IN") %></h3>
                            <p class="dash-stat-label">Your Earnings</p>
                            <small style="color: var(--text-muted);">After 15% platform fee</small>
                        </div>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(86, 84, 73, 0.1); color: var(--secondary);">
                            <i class="fa-solid fa-calendar-check"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= hostBookingsCount %></h3>
                            <p class="dash-stat-label">Bookings Received</p>
                            <% if (activeHostBookings > 0) { %>
                                <small style="color: #2d8a5e;"><%= activeHostBookings %> active</small>
                            <% } %>
                        </div>
                        <a href="/dashboard/host-bookings" class="dash-stat-link">
                            View <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="dash-stat-card">
                        <div class="dash-stat-icon" style="background: rgba(86, 84, 73, 0.1); color: var(--secondary);">
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <div class="dash-stat-info">
                            <h3 class="dash-stat-number"><%= totalReviews %></h3>
                            <p class="dash-stat-label">Reviews Received</p>
                        </div>
                        <a href="/dashboard/host-reviews" class="dash-stat-link">
                            View <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Recent Host Bookings -->
                <div class="dash-recent-card">
                    <div class="dash-recent-header">
                        <h3><i class="fa-solid fa-clock-rotate-left"></i> Recent Bookings on Your Listings</h3>
                        <% if (totalListings > 0) { %>
                            <a href="/dashboard/listings" class="dash-view-all">Manage Listings</a>
                        <% } %>
                    </div>
                    <div class="dash-recent-list">
                        <% if (recentHostBookings.length === 0) { %>
                            <div class="dash-empty-state">
                                <i class="fa-solid fa-house-user"></i>
                                <p>No bookings on your listings yet. <a href="/listings/new">Create a listing</a></p>
                            </div>
                        <% } else { %>
                            <% recentHostBookings.forEach(booking => { %>
                                <div class="dash-recent-item">
                                    <div class="dash-recent-img">
                                        <img src="<%= booking.listing?.image?.url || booking.listingImage || '' %>" alt="<%= booking.listing?.title || booking.listingTitle || 'Listing' %>">
                                    </div>
                                    <div class="dash-recent-info">
                                        <h4><%= booking.listing?.title || booking.listingTitle || 'Listing' %></h4>
                                        <p>
                                            Guest: <strong><%= booking.guestUsername || 'Guest' %></strong> &middot;
                                            <%= booking.checkIn.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' }) %>
                                            —
                                            <%= booking.checkOut.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' }) %>
                                        </p>
                                    </div>
                                    <div class="dash-recent-meta">
                                        <span class="dash-badge dash-badge-<%= booking.bookingStatus %>"><%= booking.bookingStatus %></span>
                                        <div style="text-align: right;">
                                            <span class="dash-price">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                            <% if (booking.hostEarnings !== undefined) { %>
                                                <br><small style="color: #2d8a5e; font-size: 0.75rem;">Earn: ₹<%= booking.hostEarnings.toLocaleString("en-IN") %></small>
                                            <% } else { %>
                                                <br><small style="color: #2d8a5e; font-size: 0.75rem;">Earn: ₹<%= Math.round(booking.totalPrice * 0.85).toLocaleString("en-IN") %></small>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
